<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Smart Buy Ultra Light</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root { --accent: #4f46e5; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; -webkit-tap-highlight-color: transparent; transition: background-color 0.3s; }
        .dark { background-color: #0f172a; color: #f8fafc; }
        .dark .bg-white { background-color: #1e293b; border-color: #334155; }
        .dark .text-slate-900 { color: #f1f5f9; }
        .dark .text-slate-700 { color: #cbd5e1; }
        .dark .bg-slate-50 { background-color: #1e293b; }
        
        .tab-active { color: var(--accent); border-bottom: 3px solid var(--accent); }
        .is-best { border: 2px solid #10b981 !important; background-color: rgba(16, 185, 129, 0.05); }
        .progress-bar { transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }
        .checked { opacity: 0.4; filter: grayscale(1); }
        
        @keyframes pop { 0% { transform: scale(0.95); } 100% { transform: scale(1); } }
        section { animation: pop 0.2s ease-out; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen pb-24 text-slate-900">

    <header class="bg-white sticky top-0 z-40 border-b border-slate-200 shadow-sm dark:border-slate-800">
        <div class="flex max-w-md mx-auto border-b border-slate-100 dark:border-slate-800">
            <button onclick="switchTab('shopping')" id="nav-shopping" class="flex-1 py-4 text-[10px] font-800 uppercase tracking-widest tab-active">Lista</button>
            <button onclick="switchTab('compare')" id="nav-compare" class="flex-1 py-4 text-[10px] font-800 uppercase tracking-widest text-slate-400">Comparar</button>
            <button onclick="switchTab('suppliers')" id="nav-suppliers" class="flex-1 py-4 text-[10px] font-800 uppercase tracking-widest text-slate-400">Tiendas</button>
        </div>

        <div class="max-w-md mx-auto px-4 pt-4 pb-2">
            <div class="flex justify-between items-center mb-4">
                <h1 class="text-xl font-800 tracking-tight">Smart<span class="text-indigo-600">Buy</span></h1>
                <div class="flex gap-2">
                    <button onclick="toggleDarkMode()" class="p-2 text-slate-400 hover:text-indigo-500">
                        <svg id="theme-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                    </button>
                    <button onclick="shareList()" class="p-2 text-slate-400 hover:text-indigo-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
                    </button>
                    <button onclick="clearProductsOnly()" class="p-2 text-red-300 hover:text-red-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </button>
                </div>
            </div>

            <div class="bg-indigo-900 rounded-3xl p-5 text-white shadow-xl shadow-indigo-200 dark:shadow-none">
                <div class="flex justify-between items-end mb-2">
                    <div>
                        <p class="text-[10px] font-bold uppercase tracking-widest text-indigo-300">Presupuesto</p>
                        <div class="flex items-center gap-1">
                            <span class="text-indigo-300 font-bold">$</span>
                            <input type="number" id="budgetInput" oninput="updateBudget()" class="bg-transparent text-2xl font-800 focus:outline-none w-32 placeholder:text-indigo-800" placeholder="0.00">
                        </div>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-indigo-300">Restante</p>
                        <p id="remainingBudget" class="text-2xl font-800">$0.00</p>
                    </div>
                </div>
                <div class="w-full bg-indigo-950/50 h-2 rounded-full overflow-hidden">
                    <div id="budgetProgress" class="progress-bar h-full bg-emerald-400" style="width: 0%"></div>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-md mx-auto p-4">
        
        <section id="view-shopping">
            <div class="mb-4">
                <input type="text" id="searchItem" oninput="render()" placeholder="🔍 Buscar..." class="w-full bg-white border border-slate-200 p-3 rounded-2xl text-sm outline-none focus:ring-2 focus:ring-indigo-500 dark:bg-slate-800 dark:border-slate-700">
            </div>

            <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100 mb-8 dark:bg-slate-800">
                <div class="space-y-4">
                    <input type="text" id="prodName" placeholder="¿Qué necesitas?" class="w-full border-b py-2 focus:border-indigo-500 outline-none font-semibold text-lg bg-transparent">
                    
                    <div class="flex gap-2">
                        <select id="prodSupplier" class="w-full bg-slate-50 p-3 rounded-xl text-xs font-bold outline-none border border-transparent focus:border-indigo-300 dark:bg-slate-900"></select>
                    </div>

                    <div class="flex items-center bg-slate-50 p-4 rounded-2xl border border-transparent focus-within:border-indigo-300 dark:bg-slate-900">
                        <span class="text-slate-400 font-bold mr-2">$</span>
                        <input type="number" id="prodPrice" placeholder="Precio" class="bg-transparent w-full focus:outline-none font-bold">
                        <div class="w-16 flex items-center border-l border-slate-200 ml-2 pl-2 dark:border-slate-700">
                            <span class="text-slate-400 text-xs mr-1">x</span>
                            <input type="number" id="prodQty" value="1" class="bg-transparent w-full focus:outline-none text-sm font-bold">
                        </div>
                        <button onclick="addProduct()" class="bg-indigo-600 text-white p-3 rounded-xl shadow-lg hover:scale-105 active:scale-90 transition-all ml-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 6v6m0 0v6m0-6h6m-6-0H6"></path></svg>
                        </button>
                    </div>
                </div>
            </div>

            <div id="listBySupplier" class="space-y-8"></div>
        </section>

        <section id="view-compare" class="hidden">
            <div id="comparisonContainer" class="space-y-4"></div>
        </section>

        <section id="view-suppliers" class="hidden">
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-100 mb-6 dark:bg-slate-800">
                <input type="hidden" id="editSupId">
                <h3 id="supTitle" class="font-800 text-xs uppercase tracking-widest mb-4 text-indigo-600">Nueva Tienda</h3>
                <input type="text" id="supName" placeholder="Nombre de la tienda" class="w-full border-b py-3 mb-4 outline-none font-bold text-lg bg-transparent">
                <input type="text" id="supInfo" placeholder="Ubicación o notas" class="w-full border-b py-3 mb-6 outline-none text-sm text-slate-400 bg-transparent">
                <div class="flex gap-2">
                    <button onclick="saveSupplier()" class="flex-1 bg-indigo-600 text-white py-4 rounded-2xl font-bold text-xs uppercase tracking-widest">Guardar</button>
                    <button onclick="cancelSupEdit()" id="btnCancelSup" class="hidden flex-1 bg-slate-100 text-slate-500 py-4 rounded-2xl font-bold text-xs uppercase">Cancelar</button>
                </div>
            </div>
            <div id="suppliersList" class="space-y-3"></div>
        </section>
    </main>

    <script>
        let state = JSON.parse(localStorage.getItem('smart_buy_ultra')) || {
            budget: 0,
            suppliers: [],
            products: [],
            checkedIds: [],
            darkMode: false
        };

        function save() {
            localStorage.setItem('smart_buy_ultra', JSON.stringify(state));
            render();
        }

        function vibrate() { if(navigator.vibrate) navigator.vibrate(10); }

        function toggleDarkMode() {
            state.darkMode = !state.darkMode;
            document.body.classList.toggle('dark', state.darkMode);
            save();
        }

        function switchTab(tab) {
            vibrate();
            ['shopping', 'compare', 'suppliers'].forEach(t => {
                document.getElementById(`view-${t}`).classList.add('hidden');
                document.getElementById(`nav-${t}`).classList.remove('tab-active', 'text-slate-400');
                if(t !== tab) document.getElementById(`nav-${t}`).classList.add('text-slate-400');
            });
            document.getElementById(`view-${tab}`).classList.remove('hidden');
            document.getElementById(`nav-${tab}`).classList.add('tab-active');
        }

        function shareList() {
            if (state.products.length === 0) return alert("Lista vacía");
            let text = "🛒 *MI LISTA DE COMPRAS*\n\n";
            state.suppliers.forEach(s => {
                const prods = state.products.filter(p => p.supplierId == s.id);
                if(prods.length > 0) {
                    text += `🏠 *${s.name.toUpperCase()}*\n`;
                    prods.forEach(p => {
                        text += `${state.checkedIds.includes(p.id) ? '✅' : '▫️'} ${p.name} ($${p.price})\n`;
                    });
                    text += "\n";
                }
            });
            if (navigator.share) navigator.share({ title: 'Lista de Compras', text: text });
        }

        function clearProductsOnly() {
            if(confirm('¿Borrar productos?')) {
                state.products = [];
                state.checkedIds = [];
                save();
            }
        }

        function saveSupplier() {
            const id = document.getElementById('editSupId').value;
            const name = document.getElementById('supName').value.trim();
            const info = document.getElementById('supInfo').value.trim();
            if (!name) return;
            if (id) {
                const i = state.suppliers.findIndex(s => s.id == id);
                state.suppliers[i] = { ...state.suppliers[i], name, info };
            } else {
                state.suppliers.push({ id: Date.now(), name, info });
            }
            cancelSupEdit(); save();
        }

        function cancelSupEdit() {
            document.getElementById('editSupId').value = '';
            document.getElementById('supName').value = '';
            document.getElementById('supInfo').value = '';
            document.getElementById('supTitle').innerText = "Nueva Tienda";
            document.getElementById('btnCancelSup').classList.add('hidden');
        }

        function editSupplier(id) {
            const s = state.suppliers.find(sup => sup.id == id);
            document.getElementById('editSupId').value = s.id;
            document.getElementById('supName').value = s.name;
            document.getElementById('supInfo').value = s.info;
            document.getElementById('supTitle').innerText = "Editando Tienda";
            document.getElementById('btnCancelSup').classList.remove('hidden');
            window.scrollTo(0,0);
        }

        function addProduct() {
            const n = document.getElementById('prodName').value.trim().toLowerCase();
            const p = parseFloat(document.getElementById('prodPrice').value);
            const q = parseFloat(document.getElementById('prodQty').value);
            const s = document.getElementById('prodSupplier').value;

            if (!n || isNaN(p) || !s) return alert("Completa los datos");

            state.products.push({ id: Date.now(), name: n, supplierId: Number(s), price: p, qty: q });
            document.getElementById('prodName').value = ''; 
            document.getElementById('prodPrice').value = '';
            vibrate(); save();
        }

        function toggleCheck(id) {
            if (state.checkedIds.includes(id)) {
                state.checkedIds = state.checkedIds.filter(cid => cid != id);
            } else {
                state.checkedIds.push(id);
                vibrate();
            }
            save();
        }

        function updateBudget() {
            state.budget = parseFloat(document.getElementById('budgetInput').value) || 0;
            save();
        }

        function render() {
            document.body.classList.toggle('dark', state.darkMode);
            document.getElementById('budgetInput').value = state.budget || "";
            const search = document.getElementById('searchItem').value.toLowerCase();

            const supSelect = document.getElementById('prodSupplier');
            supSelect.innerHTML = state.suppliers.length > 0 
                ? '<option value="" disabled selected>🏪 Seleccionar tienda...</option>' + state.suppliers.map(s => `<option value="${s.id}">${s.name}</option>`).join('')
                : '<option value="">⚠️ Crea una tienda primero</option>';

            const grouped = {};
            state.products.forEach(p => { if(!grouped[p.name]) grouped[p.name] = []; grouped[p.name].push(p); });

            const bestIds = {};
            let realCost = 0;
            const spendPerSup = {};

            for (const name in grouped) {
                const cheapest = grouped[name].reduce((min, p) => p.price < min.price ? p : min, grouped[name][0]);
                bestIds[name] = cheapest.id;
                realCost += (cheapest.price * cheapest.qty);
            }

            state.products.forEach(p => spendPerSup[p.supplierId] = (spendPerSup[p.supplierId] || 0) + (p.price * p.qty));

            const remaining = state.budget - realCost;
            const progress = state.budget > 0 ? Math.min((realCost / state.budget) * 100, 100) : 0;
            document.getElementById('budgetProgress').style.width = `${progress}%`;
            document.getElementById('remainingBudget').innerText = `$${remaining.toFixed(2)}`;
            document.getElementById('remainingBudget').className = `text-2xl font-800 ${remaining < 0 ? 'text-rose-400' : 'text-white'}`;

            const listUI = document.getElementById('listBySupplier');
            listUI.innerHTML = '';
            state.suppliers.forEach(sup => {
                const prods = state.products.filter(p => p.supplierId == sup.id && p.name.includes(search));
                if (prods.length > 0) {
                    let html = `<div class="mb-6"><h4 class="text-[10px] font-800 text-slate-400 uppercase px-2 mb-2 flex justify-between"><span>${sup.name}</span> <span class="text-indigo-500">$${(spendPerSup[sup.id] || 0).toFixed(2)}</span></h4>`;
                    html += `<div class="bg-white rounded-3xl border border-slate-100 divide-y divide-slate-50 shadow-sm dark:divide-slate-700 overflow-hidden">`;
                    prods.forEach(p => {
                        const isBest = bestIds[p.name] === p.id;
                        const isChecked = state.checkedIds.includes(p.id);
                        html += `
                            <div class="p-4 flex justify-between items-center ${isChecked ? 'checked' : ''}">
                                <div class="flex items-center gap-3 flex-1" onclick="toggleCheck(${p.id})">
                                    <div class="w-6 h-6 border-2 rounded-lg flex items-center justify-center ${isChecked ? 'bg-indigo-600 border-indigo-600' : 'border-slate-200'}">
                                        ${isChecked ? '<svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path></svg>' : ''}
                                    </div>
                                    <div>
                                        <p class="font-bold capitalize text-sm">${p.name}</p>
                                        <p class="text-[10px] font-bold text-slate-400 uppercase">${p.qty} x $${p.price.toFixed(2)} ${isBest ? '⭐' : ''}</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-4">
                                    <span class="font-800">$${(p.price * p.qty).toFixed(2)}</span>
                                    <button onclick="vibrate();state.products=state.products.filter(x=>x.id!=${p.id});save();" class="text-slate-200 px-2 text-xl">×</button>
                                </div>
                            </div>`;
                    });
                    html += `</div></div>`;
                    listUI.innerHTML += html;
                }
            });

            document.getElementById('suppliersList').innerHTML = state.suppliers.map(s => `
                <div class="bg-white p-4 rounded-2xl border border-slate-100 flex justify-between items-center shadow-sm dark:bg-slate-800 dark:border-slate-700">
                    <div onclick="editSupplier(${s.id})" class="flex-1">
                        <p class="font-bold text-slate-700 dark:text-slate-200">${s.name}</p>
                        <p class="text-[10px] text-indigo-500 font-bold uppercase">Gasto total: $${(spendPerSup[s.id] || 0).toFixed(2)}</p>
                    </div>
                    <button onclick="if(confirm('¿Borrar?')){state.suppliers=state.suppliers.filter(x=>x.id!=${s.id});save();}" class="text-red-200 px-2 text-xl">×</button>
                </div>
            `).join('');

            const compUI = document.getElementById('comparisonContainer');
            compUI.innerHTML = '';
            for (const name in grouped) {
                let html = `<div class="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm dark:bg-slate-800 dark:border-slate-700"><h5 class="font-800 text-indigo-500 uppercase text-[10px] mb-4 tracking-widest border-b border-slate-50 pb-2 dark:border-slate-700">${name}</h5>`;
                grouped[name].sort((a,b) => a.price - b.price).forEach(p => {
                    const isBest = bestIds[p.name] === p.id;
                    const sName = state.suppliers.find(s => s.id == p.supplierId)?.name || '...';
                    html += `<div class="flex justify-between items-center p-3 rounded-2xl mb-1 ${isBest ? 'is-best' : 'bg-slate-50 opacity-60 dark:bg-slate-900'}"><span class="text-xs font-bold">${sName}</span><span class="font-800">$${p.price.toFixed(2)}</span></div>`;
                });
                compUI.innerHTML += html + `</div>`;
            }
        }
        render();
    </script>
</body>
</html>
